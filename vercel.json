{
  "rewrites": [
    { "source": "/welcome", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)\\.(webm|mp4|mp3|png|jpg|jpeg|webp|woff2?)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=604800, stale-while-revalidate=86400"
        }
      ]
    }
  ]
}
